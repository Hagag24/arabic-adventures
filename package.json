{
  "name": "arabic-adventures",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "pnpm audio:verify:architecture && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\" \"prisma/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\" \"prisma/**/*.ts\" \"scripts/**/*.ts\"",
    "test": "cross-env DATABASE_URL=\"file:./data/test.db\" tsx scripts/prepare-test-db.ts && cross-env DATABASE_URL=\"file:./data/test.db\" vitest run --fileParallelism=false && tsx scripts/cleanup-test-db.ts",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:verify": "tsx scripts/verify-db.ts",
    "cleanup:verify": "tsx scripts/verify-cleanup.ts",
    "audio:inventory": "tsx scripts/audio/build-inventory.ts",
    "audio:audition": "tsx scripts/audio/audition.ts",
    "audio:generate": "tsx scripts/audio/generate.ts",
    "audio:normalize": "tsx scripts/audio/normalize.ts",
    "audio:verify:architecture": "tsx scripts/audio/verify.ts --mode architecture",
    "audio:verify:published": "tsx scripts/audio/verify.ts --mode published",
    "audio:publish": "tsx scripts/audio/publish.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}

{
  "name": "arabic-adventures",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "pnpm audio:verify:architecture && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\" \"prisma/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\" \"prisma/**/*.ts\" \"scripts/**/*.ts\"",
    "test": "cross-env DATABASE_URL=\"file:./data/test.db\" tsx scripts/prepare-test-db.ts && cross-env DATABASE_URL=\"file:./data/test.db\" vitest run --fileParallelism=false && tsx scripts/cleanup-test-db.ts",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:verify": "tsx scripts/verify-db.ts",
    "cleanup:verify": "tsx scripts/verify-cleanup.ts",
    "audio:audit:student": "tsx development/audio/tools/audit-student-audio.ts",
    "audio:runtime:audit": "tsx scripts/audit-all-runtime-audio.ts",
    "audio:runtime:audit:ancient-egyptian-teacher": "tsx scripts/audit-lesson1-runtime-audio.ts",
    "audio:regenerate:key": "tsx development/audio/tools/regenerate-key.ts",
    "audio:scripts:sync": "tsx development/audio/tools/sync-audio-scripts.ts",
    "audio:scripts:validate": "tsx development/audio/tools/validate-audio-scripts.ts",
    "audio:generate:resume": "tsx development/audio/tools/generate-audio-from-scripts.ts",
    "audio:verify:architecture": "tsx development/audio/tools/verify.ts --mode architecture",
    "audio:verify:published": "tsx development/audio/tools/verify.ts --mode published",
    "audio:audit:fake-assets": "tsx development/audio/tools/audit-fake-assets.ts",
    "audio:tools:typecheck": "tsc --project development/audio/tsconfig.json",
    "audio:quota:status": "tsx development/audio/tools/quota-status.ts",
    "audio:generate:auto-resume": "tsx development/audio/tools/auto-resume.ts",
    "audio:edge:setup": "py -m venv development/audio/edge-tts/.venv && .\\development\\audio\\edge-tts\\.venv\\Scripts\\python.exe -m pip install -r development/audio/edge-tts/requirements.txt",
    "audio:edge:preflight": "set PYTHONPATH=development/audio/edge-tts/src&& .\\development\\audio\\edge-tts\\.venv\\Scripts\\python.exe -m edge_audio.cli preflight",
    "audio:edge:generate:welcome": "set PYTHONPATH=development/audio/edge-tts/src&& .\\development\\audio\\edge-tts\\.venv\\Scripts\\python.exe -m edge_audio.cli generate-welcome",
    "audio:edge:generate:all": "set PYTHONPATH=development/audio/edge-tts/src&& .\\development\\audio\\edge-tts\\.venv\\Scripts\\python.exe -m edge_audio.cli generate-all",
    "audio:edge:resume": "set PYTHONPATH=development/audio/edge-tts/src&& .\\development\\audio\\edge-tts\\.venv\\Scripts\\python.exe -m edge_audio.cli resume",
    "audio:edge:status": "set PYTHONPATH=development/audio/edge-tts/src&& .\\development\\audio\\edge-tts\\.venv\\Scripts\\python.exe -m edge_audio.cli status",
    "audio:edge:verify": "set PYTHONPATH=development/audio/edge-tts/src&& .\\development\\audio\\edge-tts\\.venv\\Scripts\\python.exe -m edge_audio.cli verify",
    "audio:edge:publish": "set PYTHONPATH=development/audio/edge-tts/src&& .\\development\\audio\\edge-tts\\.venv\\Scripts\\python.exe -m edge_audio.cli publish",
    "audio:edge:regenerate:key": "set PYTHONPATH=development/audio/edge-tts/src&& .\\development\\audio\\edge-tts\\.venv\\Scripts\\python.exe -m edge_audio.cli regenerate-key",
    "audio:edge:lint": ".\\development\\audio\\edge-tts\\.venv\\Scripts\\python.exe -m ruff check development/audio/edge-tts/src/edge_audio",
    "audio:edge:typecheck": ".\\development\\audio\\edge-tts\\.venv\\Scripts\\python.exe -m mypy development/audio/edge-tts/src/edge_audio",
    "audio:edge:test": "set PYTHONPATH=development/audio/edge-tts/src&& .\\development\\audio\\edge-tts\\.venv\\Scripts\\python.exe -m pytest development/audio/edge-tts/tests"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
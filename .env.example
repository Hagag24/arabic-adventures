DATABASE_URL="file:./data/arabic-adventures.db"

# Optional developer-only Next.js diagnostics.
# Must remain false for normal visual testing.
SHOW_NEXT_DEVTOOLS=false

# Developer-only audio generation credentials.
# Do not prefix with NEXT_PUBLIC_ or bundle in client code.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AUDIO_TTS_PROVIDER=azure
AUDIO_TTS_VOICE=

